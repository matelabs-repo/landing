---
export interface Props {
  locale: string;
}

const { locale } = Astro.props;
const t = {
  label: locale === 'es' ? 'Productos' : 'Products',
  title: locale === 'es' ? 'Lo que construimos' : 'What we build',
  flux_title: 'Flux',
  flux_desc: locale === 'es' ? 'Suite OTT white-label. CMS, reproductor web, app móvil y Smart TV. Todo lo que un operador necesita para lanzar su plataforma de streaming.' : 'White-label OTT Suite. CMS, web player, mobile app and Smart TV. Everything an operator needs to launch their streaming platform.',
  flux_cta: locale === 'es' ? 'Conocer Flux' : 'Explore Flux',
  flux_stats: [
    { value: '4', label: locale === 'es' ? 'Productos' : 'Products' },
    { value: 'CMS', label: locale === 'es' ? 'Backoffice' : 'Backoffice' },
    { value: 'WEB', label: locale === 'es' ? 'Reproductor' : 'Player' },
    { value: 'MOBILE', label: locale === 'es' ? 'App' : 'App' },
  ],
};
---

<style>
  .prod {
    padding: 120px 24px;
    position: relative;
    background: #080808;
    overflow: hidden;
  }

  .prod::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(57, 181, 74, 0.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(57, 181, 74, 0.02) 1px, transparent 1px);
    background-size: 80px 80px;
    mask-image: radial-gradient(ellipse 60% 60% at 40% 50%, black 30%, transparent 70%);
  }

  .prod-inner {
    position: relative;
    z-index: 1;
    max-width: var(--content-max-width);
    margin: 0 auto;
  }

  .prod-label {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 16px;
    display: block;
  }

  .prod-title {
    font-family: var(--font-heading);
    font-size: clamp(30px, 4.5vw, 48px);
    font-weight: 700;
    color: var(--color-white);
    margin-bottom: clamp(48px, 6vw, 72px);
    line-height: 1.12;
    letter-spacing: -0.03em;
    max-width: 700px;
  }

  .prod-card {
    display: flex;
    flex-direction: column;
    gap: 32px;
    padding: 56px 40px;
    border-radius: 24px;
    border: 1px solid rgba(255, 255, 255, 0.06);
    background: linear-gradient(135deg, rgba(79, 71, 205, 0.08) 0%, rgba(128, 179, 255, 0.04) 100%);
    transition: all 0.35s ease;
    position: relative;
    overflow: hidden;
  }

  .prod-card::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(79, 71, 205, 0.4), rgba(128, 179, 255, 0.4), transparent);
    opacity: 0;
    transition: opacity 0.35s ease;
  }

  .prod-card:hover {
    border-color: rgba(79, 71, 205, 0.25);
    transform: translateY(-3px);
    box-shadow: 0 16px 60px rgba(79, 71, 205, 0.08);
  }

  .prod-card:hover::after {
    opacity: 1;
  }

  .prod-card-top {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .prod-card-badge {
    display: inline-flex;
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.5px;
    color: var(--color-primary);
    background: rgba(57, 181, 74, 0.1);
    border-radius: 8px;
    padding: 5px 12px;
    text-transform: uppercase;
    width: fit-content;
  }

  .prod-card-name {
    font-family: var(--font-heading);
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 700;
    color: var(--color-white);
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .prod-card-desc {
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.5);
    line-height: 1.7;
    max-width: 520px;
  }

  .prod-card-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    padding-top: 32px;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  .prod-stat {
    text-align: center;
  }

  .prod-stat-value {
    font-family: var(--font-heading);
    font-size: 22px;
    font-weight: 700;
    color: var(--color-white);
    letter-spacing: -0.01em;
  }

  .prod-stat-label {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.35);
    margin-top: 4px;
    letter-spacing: 0.5px;
  }

  .prod-card-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 15px;
    color: var(--color-primary);
    transition: gap 0.2s ease;
  }

  .prod-card-cta:hover {
    gap: 12px;
  }

  @media (min-width: 768px) {
    .prod-card {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
    .prod-card-top {
      max-width: 55%;
    }
    .prod-card-stats {
      border-top: none;
      border-left: 1px solid rgba(255, 255, 255, 0.05);
      padding-top: 0;
      padding-left: 32px;
    }
    .prod-card-cta {
      align-self: flex-end;
    }
  }
</style>

<section class="prod" id="productos">
  <div class="prod-inner">
    <span class="prod-label">{t.label}</span>
    <h2 class="prod-title">{t.title}</h2>
    <div class="prod-card">
      <div class="prod-card-top">
        <span class="prod-card-badge">Activo</span>
        <h3 class="prod-card-name">{t.flux_title}</h3>
        <p class="prod-card-desc">{t.flux_desc}</p>
      </div>
      <div class="prod-card-stats">
        {t.flux_stats.map(stat => (
          <div class="prod-stat">
            <div class="prod-stat-value">{stat.value}</div>
            <div class="prod-stat-label">{stat.label}</div>
          </div>
        ))}
      </div>
      <a class="prod-card-cta" href={`/${locale}/flux/`}>
        {t.flux_cta}
        <span>→</span>
      </a>
    </div>
  </div>
</section>
