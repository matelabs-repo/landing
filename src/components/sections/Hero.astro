---
export interface Props {
  data: {
    hero: {
      claim_pre: string;
      claim_accent: string;
      claim_post: string;
      extension: string;
      cta: string;
    };
  };
}

const { data } = Astro.props;
const { hero } = data;
---

<style>
  .hero {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    min-height: 100vh;
    padding: 100px 24px 80px;
    overflow: hidden;
    isolation: isolate;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.25;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(8, 8, 8, 0.95) 0%,
      rgba(8, 8, 8, 0.7) 50%,
      rgba(8, 8, 8, 0.95) 100%
    );
    z-index: 1;
  }

  .hero-accent {
    position: absolute;
    top: 30%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: min(800px, 80vw);
    height: min(800px, 80vw);
    background: radial-gradient(circle at center, rgba(57, 181, 74, 0.08) 0%, transparent 60%);
    z-index: 1;
    pointer-events: none;
    border-radius: 50%;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 800px;
  }

  .hero-logo {
    height: clamp(44px, 7vw, 70px);
    width: auto;
    margin-bottom: clamp(32px, 5vh, 56px);
  }

  .hero-claim {
    font-family: var(--font-heading);
    font-size: clamp(30px, 5.5vw, 60px);
    font-weight: 700;
    color: var(--color-white);
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin-bottom: 20px;
  }

  .hero-claim-accent {
    color: var(--color-primary);
  }

  .hero-ext {
    font-family: var(--font-body);
    font-size: clamp(16px, 2vw, 19px);
    font-weight: 400;
    color: rgba(255, 255, 255, 0.55);
    max-width: 560px;
    line-height: 1.65;
    margin-bottom: 44px;
  }

  .hero-actions {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--color-primary);
    color: var(--color-black);
    font-family: var(--font-body);
    font-weight: 600;
    font-size: clamp(15px, 1.8vw, 17px);
    padding: 15px 32px;
    border-radius: 10px;
    transition: all 0.25s ease;
    cursor: pointer;
  }

  .hero-cta:hover {
    background: #4cc95e;
    transform: translateY(-2px);
    box-shadow: 0 10px 40px rgba(57, 181, 74, 0.35);
  }

  .hero-cta-secondary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(255, 255, 255, 0.06);
    color: rgba(255, 255, 255, 0.8);
    font-family: var(--font-body);
    font-weight: 500;
    font-size: clamp(15px, 1.8vw, 17px);
    padding: 15px 32px;
    border-radius: 10px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    transition: all 0.25s ease;
    cursor: pointer;
  }

  .hero-cta-secondary:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.2);
    color: var(--color-white);
    transform: translateY(-2px);
  }
</style>

<section class="hero">
  <div class="hero-bg">
    <img src="/images/hero/01.jpg" alt="" aria-hidden="true" loading="eager" />
  </div>
  <div class="hero-overlay"></div>
  <div class="hero-accent"></div>
  <div class="hero-content">
    <img class="hero-logo" src="/assets/logo-white.svg" alt="mateLabs" />
    <h1 class="hero-claim">
      {hero.claim_pre}<span class="hero-claim-accent">{hero.claim_accent}</span>{hero.claim_post}
    </h1>
    <p class="hero-ext">{hero.extension}</p>
    <div class="hero-actions">
      <a class="hero-cta" href="#contacto">
        {hero.cta}
        <span>→</span>
      </a>
    </div>
  </div>
</section>
