<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>mateLabs</title>
  <script>
    const lang = (navigator.language || '').toLowerCase().startsWith('en') ? 'en' : 'es';
    window.location.replace('/' + lang + '/');
  </script>
</head>
<body>
  <p style="text-align:center;margin-top:40vh;font-family:sans-serif;color:#58595b;">
    Redirecting&hellip; <a href="/es/">ES</a> &middot; <a href="/en/">EN</a>
  </p>
</body>
</html>
